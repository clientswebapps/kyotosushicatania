rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Public Collections (read-only for everyone) ───
    // Menu items, categories, hero slides, promotions, and gallery
    // are publicly readable so the website can display them.
    match /menuItems/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /menuCategories/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /heroSlides/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /promotions/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /featuredItems/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /galleryItems/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ─── Reservations ───
    // Anyone can CREATE a reservation (the public form).
    // Only authenticated admins can read, update, or delete.
    match /reservations/{docId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    // ─── Admin Users Registry ───
    // Only authenticated admins can read/write the admin users list.
    match /adminUsers/{docId} {
      allow read, write: if request.auth != null;
    }

    // ─── Deny everything else by default ───
    // Any collection not explicitly listed above is blocked.
  }
}
